# ==============================================================================
# EMA Education Platform - Environment Configuration
# ==============================================================================
# Copy this file to .env and update values for your environment
# Never commit .env file with real credentials!
# ==============================================================================

# Application Environment
# Controls application runtime mode and display settings
# Values: development, staging, production
APP_ENV=development
# Enable/disable application debugging (shows detailed errors)
APP_DEBUG=true
# Base URL for the application (include protocol, no trailing slash)
APP_URL=http://localhost

# ==============================================================================
# Database Configuration
# ==============================================================================
# MySQL database connection settings
DB_HOST=localhost
# Default MySQL port (3306)
DB_PORT=3306
# Database name (use different names for dev/staging/production)
DB_NAME=theemaeducation_ema_org
# Database user with appropriate permissions (use separate user for production)
DB_USER=root
# Database password (use strong password in production)
DB_PASSWORD=
# Database character set for UTF-8 support (utf8mb4 recommended)
DB_CHARSET=utf8mb4
# Optional: Database table prefix for multiple installations
DB_PREFIX=ema_

# ==============================================================================
# Security Configuration
# ==============================================================================
# Application key for cryptographic operations (32 characters, generate securely!)
# IMPORTANT: Change this in production environments!
APP_KEY=your_32_character_random_key_here_change_in_production
# Session lifetime in seconds (172800 = 2 days, matches implementation)
SESSION_LIFETIME=172800
# CSRF token length in characters (32 bytes)
CSRF_TOKEN_LENGTH=32

# ==============================================================================
# CORS (Cross-Origin Resource Sharing) Configuration
# ==============================================================================
# Allowed origins for API access (comma-separated, * for all)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Allowed HTTP methods (comma-separated)
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
# Allowed custom headers (comma-separated)
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ==============================================================================
# Rate Limiting Configuration
# ==============================================================================
# Enable/disable rate limiting for all requests
RATE_LIMIT_ENABLED=true
# Maximum requests per window for general requests
RATE_LIMIT_MAX_REQUESTS=100
# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW=60

# User-specific rate limiting (additional protection for authenticated users)
RATE_LIMIT_USER_ENABLED=false
# Maximum requests per window for individual users
RATE_LIMIT_USER_MAX_REQUESTS=50
# User rate limiting time window
RATE_LIMIT_USER_WINDOW=60

# ==============================================================================
# File Upload Configuration
# ==============================================================================
# Maximum file size in bytes (10485760 = 10MB default)
UPLOAD_MAX_FILE_SIZE=10485760
# Allowed MIME types (comma-separated, includes images, documents, audio, video)
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,video/mp4,video/webm,audio/mpeg,audio/mp3,audio/wav,audio/aac
# Directory for uploaded files (relative to project root)
UPLOAD_PATH=uploads
# Optional: Generated thumbnail dimensions
UPLOAD_THUMBNAIL_WIDTH=300
UPLOAD_THUMBNAIL_HEIGHT=300

# ==============================================================================
# Logging Configuration
# ==============================================================================
# Log channel name (stack, file, syslog)
LOG_CHANNEL=stack
# Logging level (debug, info, warning, error, critical)
LOG_LEVEL=debug
# Directory for log files (relative to project root)
LOG_PATH=logs
# Maximum log file size in bytes before rotation
LOG_MAX_FILE_SIZE=10485760

# ==============================================================================
# Cache Configuration
# ==============================================================================
# Cache driver (file, redis, memcached, apcu)
CACHE_DRIVER=file
# Cache time-to-live in seconds (3600 = 1 hour default)
CACHE_TTL=3600
# Cache key prefix to avoid conflicts
CACHE_PREFIX=ema_

# ==============================================================================
# Session Configuration
# ==============================================================================
# Session storage driver (file, redis, memcached)
SESSION_DRIVER=file
# Directory for session files (relative to project root)
SESSION_PATH=storage/sessions
# Session cookie domain (empty = current domain)
SESSION_DOMAIN=.localhost
# Only send cookies over HTTPS (set true in production)
SESSION_SECURE=false
# Prevent JavaScript access to cookies (security best practice)
SESSION_HTTP_ONLY=true
# Same-site cookie policy (strict, lax, none)
SESSION_SAME_SITE=lax

# ==============================================================================
# Email Configuration (if needed for notifications)
# ==============================================================================
# SMTP server hostname for sending emails
MAIL_HOST=smtp.gmail.com
# SMTP server port (587 = standard, 465 = secure, 25 = legacy)
MAIL_PORT=587
# SMTP username (email address or API username)
MAIL_USERNAME=
# SMTP password (use app-specific password for production)
MAIL_PASSWORD=
# From email address for notifications
MAIL_FROM=noreply@emaeducation.com
# From display name for notifications
MAIL_FROM_NAME=EMA Education

# ==============================================================================
# Admin Configuration
# ==============================================================================
# Administrator email address for system notifications
ADMIN_EMAIL=admin@emaeducation.com
# Administrator name for notifications and logs
ADMIN_NAME=System Administrator

# ==============================================================================
# Time Configuration
# ==============================================================================
# Server timezone (use PHP timezone names: UTC, America/New_York, Europe/London)
TIMEZONE=UTC
# Default date format (Y-m-d H:i:s = 2026-04-22 14:30:45)
DATE_FORMAT=Y-m-d H:i:s
# Default datetime format (Y-m-d H:i:s = 2026-04-22 14:30:45)
DATETIME_FORMAT=Y-m-d H:i:s

# ==============================================================================
# Performance Monitoring Configuration
# ==============================================================================
# Log all SQL queries (useful for debugging, disable in production)
ENABLE_QUERY_LOGGING=false
# Log queries that take longer than threshold (milliseconds)
ENABLE_SLOW_QUERY_LOGGING=true
# Threshold in milliseconds to consider query "slow" (2000 = 2 seconds)
SLOW_QUERY_THRESHOLD=2000

# ==============================================================================
# Maintenance Mode
# ==============================================================================
# Enable/disable maintenance mode (true = block non-admin access)
MAINTENANCE_MODE=false
# Maintenance message shown to users when maintenance is active
MAINTENANCE_MESSAGE=System is currently under maintenance. Please try again later.

# ==============================================================================
# Pagination Configuration
# ==============================================================================
# Default page number for pagination (1-indexed)
PAGINATION_DEFAULT_PAGE=1
# Default items per page for pagination lists
PAGINATION_DEFAULT_PER_PAGE=20
# Maximum items per page for pagination (prevents excessive data loading)
PAGINATION_MAX_PER_PAGE=100

# ==============================================================================
# User Limits
# ==============================================================================
# Minimum password length requirement
USER_MIN_PASSWORD_LENGTH=8
# Maximum password length limit
USER_MAX_PASSWORD_LENGTH=128
# Maximum failed login attempts before account lock
USER_MAX_LOGIN_ATTEMPTS=5
# Time window in seconds for login attempts tracking
USER_LOGIN_ATTEMPT_WINDOW=900

# ==============================================================================
# File Limits
# ==============================================================================
# Maximum files per single upload request
MAX_UPLOAD_FILES_PER_REQUEST=10
# Maximum files per folder
MAX_FILES_PER_FOLDER=500

# ==============================================================================
# Quiz Configuration
# ==============================================================================
# Enable/disable time limit for quiz attempts
QUIZ_TIME_LIMIT_ENABLED=false
# Quiz time limit in minutes (when enabled)
QUIZ_TIME_LIMIT_MINUTES=60
# Default passing score percentage (70%)
QUIZ_PASSING_SCORE_DEFAULT=70
# Maximum quiz attempts per user per quiz set
QUIZ_MAX_ATTEMPTS_PER_USER=3

# ==============================================================================
# Connection Pooling Configuration
# ==============================================================================
# Enable/disable database connection pooling (improves performance)
CONNECTION_POOL_ENABLED=true
# Maximum simultaneous connections in pool (reduces connection overhead)
CONNECTION_POOL_MAX_SIZE=10
# Connection timeout in seconds before considering connection dead (30 = 30 seconds)
CONNECTION_POOL_TIMEOUT=30
